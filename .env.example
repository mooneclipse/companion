# Telegram bot token (from BotFather, https://t.me/BotFather, /newbot)
# 取得後すぐに `.env` へ移し、`.env` は chmod 600 で保管する。
TELEGRAM_BOT_TOKEN=

# OWNER の Telegram user.id (取得: @userinfobot に /start)
OWNER_ID=

# socket-routed 通知の宛先 supergroup chat_id (負値、例: -100xxxxxxxxxx)
# 取得手順は bot/docs/telegram-setup.md §4 を参照。
NOTIFY_CHAT_ID=

# forum topic id (整数、bot/docs/telegram-setup.md §4 で取得)
BOT_THREAD_ID_CHAT=
BOT_THREAD_ID_RESEARCH=
# socket 通知 (`maintenance/lib/notify.sh`) の forward 先 topic。
# 空文字 = General topic にフォールバック。
BOT_THREAD_ID_MAINTENANCE=
# Phase 3-2 voice 統合時に埋める (空のままなら MAINTENANCE 落ち)。
BOT_THREAD_ID_VOICE_LOG=

# Absolute path to the `claude` CLI (e.g. ~/.nvm/versions/node/<ver>/bin/claude)
CLAUDE_BIN=

# CWD passed to `claude -p` (Phase 2.5 onward: dedicated bot-workspace)
CLAUDE_CWD=/home/miho/companion/bot-workspace

# Subprocess timeout in seconds
CLAUDE_TIMEOUT=300

# BudgetGuard implementation: requests_count or credit_usd. ENV is the master
# switch (design.md §4.2). credit_usd は 2026-05-19 即時前倒し有効化、6/15
# Anthropic 制度移行を待たず ledger 集計で完結。
BOT_BUDGET_GUARD=credit_usd

# RequestsCountGuard: rolling 1h request-count cap. default 20 (実弾運用で再調整).
# (credit_usd 経路では未使用、requests_count に戻す時のため残置)
BOT_REQUESTS_PER_HOUR=20

# CreditBudgetGuard: monthly $100 credit cap. Anthropic Max 5x プラン 2026-06-15
# 開始の `claude -p` / Agent SDK 月次クレジット枠 (公式メール、design.md §4.1 UQ-5)。
# 月初 (00:00 +09:00) リセット、超過時は「月初までクールダウン」メッセージ。
BOT_MONTHLY_CREDIT_USD=100

# --- proactive companion messaging (自発発話、最小初版) ----------------------
# 出典: ~/companion/vault/notes/2026-05-30_proactive-companion-messaging-design.md
# bot 側 (PROACTIVE_ENABLED) と script 側 (同名 env) の双方で参照する。bot 側で
# off にすると socket 依頼を受けても skip する (二重防御、env で全停止可能)。
# 0/false/no/off で無効、それ以外 (default 1) で有効。
PROACTIVE_ENABLED=1
# 以下は判定スクリプト (maintenance/scripts/proactive-companion.sh) 側で参照する
# 調整パラメータ。bot.service には不要 (script の実行環境に渡す場合のみ)。
# 発火時間帯 (JST、START 以上 END 未満)。深夜除外。
PROACTIVE_HOUR_START=9
PROACTIVE_HOUR_END=22
# 沈黙閾値 (時間)。全 topic の max(last_prompt_at) からこの時間超で候補。
PROACTIVE_SILENCE_HOURS=6
# 発火確率 (0.0〜1.0)。種ありかつ条件成立時にこの確率で発火 (毎回は出さない)。
PROACTIVE_PROBABILITY=0.4

# Telegram bot token (from BotFather, https://t.me/BotFather, /newbot)
# 取得後すぐに `.env` へ移し、`.env` は chmod 600 で保管する。
TELEGRAM_BOT_TOKEN=

# OWNER の Telegram user.id (取得: @userinfobot に /start)
OWNER_ID=

# socket-routed 通知の宛先 supergroup chat_id (負値、例: -100xxxxxxxxxx)
# 取得手順は bot/docs/telegram-setup.md §4 を参照。
NOTIFY_CHAT_ID=

# forum topic id (整数、bot/docs/telegram-setup.md §4 で取得)
BOT_THREAD_ID_CHAT=
BOT_THREAD_ID_RESEARCH=
# socket 通知 (`maintenance/lib/notify.sh`) の forward 先 topic。
# 空文字 = General topic にフォールバック。
BOT_THREAD_ID_MAINTENANCE=
# Phase 3-2 voice 統合時に埋める (空のままなら MAINTENANCE 落ち)。
BOT_THREAD_ID_VOICE_LOG=

# Absolute path to the `claude` CLI (e.g. ~/.nvm/versions/node/<ver>/bin/claude)
CLAUDE_BIN=

# CWD passed to `claude -p` (Phase 2.5 onward: dedicated bot-workspace)
CLAUDE_CWD=/home/miho/companion/bot-workspace

# Subprocess timeout in seconds
CLAUDE_TIMEOUT=300

# BudgetGuard implementation: requests_count。ENV master switch (design.md §4.2)。
# bot 経由の `claude -p` 消費は Anthropic subscription の usage limit から引かれる
# (2026-06-15 予定の月次クレジット枠分離は公式に pause、当面サブスク消費前提)。
BOT_BUDGET_GUARD=requests_count

# RequestsCountGuard: rolling 1h request-count cap. default 20 (実弾運用で再調整).
# bot 経由暴走で subscription の usage limit を食い潰さない自衛。
BOT_REQUESTS_PER_HOUR=20

# --- proactive companion messaging (自発発話、最小初版) ----------------------
# 出典: ~/companion/vault/notes/2026-05-30_proactive-companion-messaging-design.md
# bot 側 (PROACTIVE_ENABLED) と script 側 (同名 env) の双方で参照する。bot 側で
# off にすると socket 依頼を受けても skip する (二重防御、env で全停止可能)。
# 0/false/no/off で無効、それ以外 (default 1) で有効。
PROACTIVE_ENABLED=1
# 以下は判定スクリプト (maintenance/scripts/proactive-companion.sh) 側で参照する
# 調整パラメータ。bot.service には不要 (script の実行環境に渡す場合のみ)。
# 発火時間帯 (JST、START 以上 END 未満)。深夜除外。
PROACTIVE_HOUR_START=9
PROACTIVE_HOUR_END=22
# 沈黙閾値 (時間)。全 topic の max(last_prompt_at) からこの時間超で候補。
PROACTIVE_SILENCE_HOURS=6
# 発火確率 (0.0〜1.0)。種ありかつ条件成立時にこの確率で発火 (毎回は出さない)。
PROACTIVE_PROBABILITY=0.4
# 関心 state (persona 軸 4 拡張 機構 1) のスレッドが触られないと消えるまでの日数。
# bot 側で参照 (sessions/companion_interests.json の decay)。default 14。
PROACTIVE_INTEREST_TTL_DAYS=14
# 自律ループの「動く」分岐 (persona 軸 4 拡張 (3) = notes 自己調査)。発火回のうち
# 条件成立時に関心スレッド 1 本を Web 調査 → vault notes/ に新規ノート作成 → #chat に
# 一言報告する。0/false/no/off で無効 (従来の「喋る」のみ)、それ以外 (default 1) で有効。
PROACTIVE_INVESTIGATE_ENABLED=1
# 前回 investigate からこの日数以上空いた発火回でのみ「動く」(未設定 = 一度も調査して
# いない = due)。index トップレベル last_investigate (ISO) を state として引く。default 7。
PROACTIVE_INVESTIGATE_INTERVAL_DAYS=7
# 自律ループの「動く」分岐 (もう一系統)。発火回のうち条件成立時に、最近の自分の活動を
# 振り返って OWNER との共用 TODO に自分から 1 件だけ起票し #chat に一言報告する。
# 0/false/no/off で無効、それ以外 (default 1) で有効。
PROACTIVE_TICKET_ENABLED=1
# 前回 ticket 起票からこの日数以上空いた発火回でのみ「動く」(未設定 = 一度も起票して
# いない = due)。index トップレベル last_ticket (ISO) を state として引く。default 7。
PROACTIVE_TICKET_INTERVAL_DAYS=7
# 自律ループの「振り返る」分岐 (persona 軸 4 拡張 (5) = リマインド)。発火回のうち
# investigate / ticket が出なかった回で条件成立時に、過去に触れた関心スレッド
# (decay しかけ / researched 済み) や自分が起票したチケットを振り返って #chat に
# 「そういえば○○どうなった?」と一言投げる (外向き/不可逆操作はゼロ)。0/false/no/off で
# 無効、それ以外 (default 1) で有効。
PROACTIVE_REMIND_ENABLED=1
# 前回 reminder からこの日数以上空いた発火回でのみ「振り返る」(未設定 = 一度も振り返って
# いない = due)。index トップレベル last_remind (ISO) を state として引く。default 7。
PROACTIVE_REMIND_INTERVAL_DAYS=7

# Discord bot token (from https://discord.com/developers/applications)
DISCORD_TOKEN=

# Discord user ID allowed to interact with the bot
OWNER_ID=

# Discord text channel ID for socket-routed notifications (Phase 2 reports etc.)
NOTIFY_CHANNEL_ID=

# Absolute path to the `claude` CLI (e.g. ~/.nvm/versions/node/<ver>/bin/claude)
CLAUDE_BIN=

# CWD passed to `claude -p` (Phase 2.5 onward: dedicated bot-workspace)
CLAUDE_CWD=/home/miho/companion/bot-workspace

# Subprocess timeout in seconds
CLAUDE_TIMEOUT=300

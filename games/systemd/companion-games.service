[Unit]
Description=companion games (静的ゲーム PWA 配信サーバ, 127.0.0.1)
Documentation=file://%h/companion/games/docs/STATUS.md

[Service]
Type=simple
WorkingDirectory=%h/companion/games
# GAMES_PORT(デフォルト 47825)を渡す。.env は任意(- 付きで不在でも起動)。
EnvironmentFile=-%h/companion/games/.env
ExecStart=%h/companion/games/server/app.py
# 常駐 HTTP サーバなのでクラッシュ時は再起動(stateless、回復に state 引きは不要)。
Restart=on-failure
RestartSec=3

[Install]
WantedBy=default.target

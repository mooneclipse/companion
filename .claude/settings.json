{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "japanese",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1"
  },
  "permissions": {
    "deny": [
      "Bash(rm -rf /*)",
      "Bash(rm -rf /)",
      "Bash(rm -rf ~)",
      "Bash(rm -rf ~/*)",
      "Bash(rm -rf $HOME*)",
      "Bash(sudo rm:*)",
      "Read(~/.ssh/**)",
      "Read(~/.aws/credentials)",
      "Read(~/.aws/config)",
      "Read(~/.config/gcloud/**)",
      "Read(~/.claude/.credentials.json)",
      "Read(~/.netrc)",
      "Read(.env)",
      "Read(.env.*)",
      "Bash(curl * | sh*)",
      "Bash(curl * | bash*)",
      "Bash(wget * | sh*)",
      "Bash(wget * | bash*)",
      "Bash(git push --force*)",
      "Bash(git push -f*)",
      "Bash(git push --force-with-lease*)",
      "Bash(git reset --hard:*)",
      "Bash(git rebase -i:*)",
      "Bash(git checkout --:*)",
      "Bash(git restore --source*)",
      "Bash(tailscale funnel:*)"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(npm publish:*)",
      "Bash(rm -rf:*)",
      "Bash(tailscale serve:*)"
    ],
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git status:*)",
      "Bash(git status)",
      "Bash(git diff:*)",
      "Bash(git diff)",
      "Bash(git log:*)",
      "Bash(git show:*)",
      "Bash(git branch:*)",
      "Bash(git branch)",
      "Bash(git restore --staged:*)",
      "Bash(git remote:*)",
      "Bash(git config:*)",
      "Bash(git fetch:*)",
      "Bash(git init:*)",
      "Bash(git pull:*)",
      "Bash(claude -p:*)",
      "Bash(claude --help:*)",
      "Bash(claude --version)",
      "Bash(uuidgen)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(grep:*)",
      "Bash(rg:*)",
      "Bash(find:*)",
      "Bash(curl:*)",
      "Bash(docker:*)",
      "Bash(podman:*)",
      "Bash(systemctl --user:*)",
      "Bash(free:*)",
      "Bash(top -bn1:*)",
      "Bash(ps:*)",
      "Bash(aplay:*)",
      "Bash(mpv:*)",
      "Bash(wget:*)",
      "Bash(which:*)",
      "Bash(command -v:*)",
      "Bash(dpkg -l:*)",
      "Bash(apt list:*)",
      "Bash(test:*)",
      "Bash(pgrep:*)",
      "Bash(xrandr:*)",
      "Bash(paplay:*)",
      "Bash(pactl:*)",
      "Bash(awk:*)",
      "Bash(jq:*)",
      "Bash(date:*)",
      "Bash(hostname:*)",
      "Bash(whoami)",
      "Bash(id:*)",
      "Bash(uname:*)",
      "Bash(env)",
      "Bash(locale:*)",
      "Bash(timedatectl:*)",
      "Bash(wc:*)",
      "Bash(sort:*)",
      "Bash(uniq:*)",
      "Bash(diff:*)",
      "Bash(tr:*)",
      "Bash(cut:*)",
      "Bash(echo:*)",
      "Bash(printf:*)",
      "Bash(file:*)",
      "Bash(stat:*)",
      "Bash(du:*)",
      "Bash(df:*)",
      "Bash(md5sum:*)",
      "Bash(sha256sum:*)",
      "Bash(udevadm:*)",
      "Bash(journalctl --user:*)",
      "Bash(lsmod:*)",
      "Bash(lspci:*)",
      "Bash(lsusb:*)",
      "Bash(xset:*)",
      "Bash(xprop:*)",
      "Bash(xwininfo:*)",
      "Bash(pacmd:*)",
      "Bash(amixer:*)",
      "Bash(pulseaudio:*)",
      "Bash(tailscale status*)",
      "Bash(tailscale ip*)",
      "Bash(tailscale netcheck*)",
      "Bash(tailscale version*)",
      "Bash(tailscale serve status*)",
      "Bash(tailscale cert*)",
      "Bash(ss:*)",
      "Bash(netstat:*)",
      "WebSearch",
      "WebFetch"
    ],
    "additionalDirectories": [
      "/home/miho/companion/vault",
      "/home/miho/companion/logs"
    ]
  }
}

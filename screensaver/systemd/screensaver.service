[Unit]
Description=Generative art screensaver (TV display)

[Service]
Type=simple
Restart=no
Environment=DISPLAY=:0
WorkingDirectory=%h/companion/screensaver
ExecStartPre=/bin/sh -c 'i=0; while [ "$i" -lt 20 ]; do [ -e /tmp/.X11-unix/X0 ] && exit 0; i=$((i+1)); sleep 1; done; echo "X11 socket not present" >&2; exit 1'
ExecStart=%h/companion/screensaver/bin/screensaver-start.sh
KillMode=control-group
TimeoutStopSec=15s
